---
import DynamicIsland from '../components/DynamicIsland.astro';
import Nav from '../components/Nav.astro';
import SobreMi from '../components/SobreMi.astro';
import Proyectos from '../components/Proyectos.astro';
import Layout from '../layouts/Layout.astro';

import t from '../i18n/es';
---

<Layout
  title="Alvaro Gómez - Portfolio"
  author="Alvaro Gómez"
  description="Bienvenido a mi portfolio. Soy Álvaro Gómez, desarrollador web apasionado especializado en crear sitios web dinámicos y responsivos."
  keywords="Alvaro Gómez, portfolio, desarrollador web, proyectos, habilidades, diseño responsivo"
  lang="es"
>
  <DynamicIsland lang="es" t={t} />
  <Nav lang="es" />
  <SobreMi lang="es" t={t} />
  <Proyectos lang="es" t={t} />

</Layout>

---
import type { EducacionT, CertificacionesT } from '../i18n/types';
import SectionTitle from './SectionTitle.astro';
import EducacionIcon from '../assets/icons/EducacionIcon.astro';
import CertificacionIcon from '../assets/icons/CertificacionIcon.astro';

interface Props {
  t: {
    educacion: EducacionT;
    certificaciones: CertificacionesT;
  };
}

const { t } = Astro.props;
---

<section
  id="educacion"
  data-section-id="educacion"
  class="w-full max-w-4xl mt-12 grid grid-cols-1 md:grid-cols-2 gap-6 items-start"
>

  <!-- ── Educación ──────────────────────────────────────────────────── -->
  <div class="flex flex-col gap-4">

    <div class="reveal">
      <SectionTitle title={t.educacion.title}>
        <EducacionIcon />
      </SectionTitle>
    </div>

    {t.educacion.items.map(item => (
      <div class="glass rounded-3xl p-6 flex flex-col gap-2 reveal">
        <div class="flex items-start justify-between gap-2 flex-wrap">
          <p class="text-sm font-semibold leading-tight">
            {item.school} <span class="opacity-40">·</span> {item.city}
          </p>
          <span class="font-mono text-[11px] tabular-nums opacity-40 shrink-0 mt-0.5">{item.period}</span>
        </div>
        <div class="flex items-center gap-2 flex-wrap">
          <span class="text-sm font-medium text-(--accent-2)">{item.degree}</span>
          {item.current && <span class="badge">{t.educacion.currentLabel}</span>}
        </div>
        <p class="text-xs leading-relaxed opacity-50">{item.description}</p>
      </div>
    ))}

  </div>

  <!-- ── Certificaciones ────────────────────────────────────────────── -->
  <div class="flex flex-col gap-4">

    <div class="reveal">
      <SectionTitle title={t.certificaciones.title}>
        <CertificacionIcon />
      </SectionTitle>
    </div>

    {t.certificaciones.items.map(cert => (
      <div class="glass rounded-2xl px-5 py-4 flex items-center gap-4 reveal">
        <div class="icon-box w-9 h-9 rounded-xl [&>svg]:w-4.5 [&>svg]:h-4.5">
          <CertificacionIcon />
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-semibold leading-tight truncate">{cert.name}</p>
          <p class="text-[11px] mt-0.5 opacity-40">{cert.provider}</p>
        </div>
        <span class="badge shrink-0">{t.certificaciones.statusLabel}</span>
      </div>
    ))}

  </div>

</section>

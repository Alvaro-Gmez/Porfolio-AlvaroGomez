---
import type { SobreMiT } from '../i18n/types';
import SectionTitle from './SectionTitle.astro';
import DownloadIcon from '../assets/icons/DownloadIcon.astro';
import PersonIcon from '../assets/icons/PersonIcon.astro';

import { Image } from 'astro:assets';
import urlAvatar from '../assets/images/alvaro_avatar.webp';

interface Props {
  t: { sobreMi: SobreMiT; location: string };
}

const { t } = Astro.props;
const s = t.sobreMi;

const urlCV = '/assets/files/Álvaro_Gómez_CV.pdf';
const linkedinURL = 'https://www.linkedin.com/in/alvarogomezd/';
---

<section
  id="inicio"
  data-section-id="inicio"
  class="w-full max-w-4xl mt-25 flex flex-col gap-4"
>

  <div class="reveal">
    <SectionTitle title={s.title} as="p">
      <PersonIcon />
    </SectionTitle>
  </div>

  <div class="glass rounded-3xl p-8 flex flex-col gap-8 reveal">

    <!-- Pills -->
    <div class="flex items-center gap-3 flex-wrap text-sm">
      <span class="chip flex items-center gap-2 px-4 py-1.5">
        <span class="w-2 h-2 rounded-full bg-(--accent-2)"></span>
        {s.role}
      </span>
      <span class="chip flex items-center gap-2 px-4 py-1.5">
        <span class="w-2 h-2 rounded-full bg-red-400"></span>
        {t.location}
      </span>
    </div>

    <!-- Contenido principal -->
    <div class="flex flex-col sm:flex-row gap-8 items-center sm:items-start">

      <!-- Retrato -->
      <div class="w-64 relative flex items-center justify-center shrink-0 rounded-2xl overflow-hidden border border-(--accent-soft)">
        <Image src={urlAvatar} alt="Álvaro Gómez" class="w-full h-full object-contain object-top" loading="eager" fetchpriority="high" />
        <div class="absolute bottom-3 left-1/2 -translate-x-1/2 w-max">
          <a href={linkedinURL} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2">
            <span class="glass glass-strong flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-medium whitespace-nowrap" >
              <span class="w-2 h-2 rounded-full bg-(--green) animate-pulse"></span>
              {s.available}
            </span>
          </a>
        </div>
      </div>

      <!-- Biografía -->
      <div class="flex flex-col text-pretty gap-5 flex-1 min-w-0">
        <div>
          <p class="text-base opacity-60 mb-1">{s.greeting}</p>
          <h1 class="text-5xl font-extrabold leading-tight tracking-tight">
            Álvaro <span class="text-gradient">Gómez</span>
          </h1>
          <p class="mt-2 text-sm opacity-60 font-medium">{s.subtitle}</p>
        </div>

        <div class="flex flex-col gap-3 text-sm leading-relaxed opacity-80">
          <p>{s.bio1}</p>
          <p>{s.bio2}</p>
        </div>

        <!-- Datos rápidos -->
        <div class="grid grid-cols-1 min-[420px]:grid-cols-2 gap-3">
          {[s.infoCards.rol, s.infoCards.stack, s.infoCards.location, s.infoCards.focus].map(card => (
            <div class="chip px-4 py-3 rounded-xl! flex flex-col gap-1">
              <span class="text-[10px] font-semibold tracking-widest opacity-50">{card.label}</span>
              <span class="text-sm font-medium">{card.value}</span>
            </div>
          ))}
        </div>

        <!-- Botones -->
        <div class="flex items-center gap-3 flex-wrap">
          <a href={urlCV}
            download
            class="flex items-center gap-2 px-5 py-2.5 rounded-full bg-(--accent) text-white text-sm font-semibold hover:-translate-y-0.5 transition-transform"
          >
            {s.downloadCV}
            <DownloadIcon />
          </a>
          <a
            href="#proyectos"
            class="chip px-5 py-2.5 text-sm font-semibold"
          >
            {s.viewProjects}
          </a>
        </div>

      </div>
    </div>
  </div>
</section>
